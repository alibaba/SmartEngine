<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alibaba.smart.framework.engine.persister.database.dao.ProcessInstanceDAO">

    <sql id="baseColumn">
        id, gmt_create, gmt_modified, process_definition_id_and_version,process_definition_type,start_user_id,
        status, complete_time, parent_process_instance_id,parent_execution_instance_id, reason, biz_unique_id, title,tag,comment,tenant_id
    </sql>

    <insert id="insert"
            parameterType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity"
            keyProperty="id">
        insert into se_process_instance (<include refid="baseColumn"/>)
        values (#{id}, #{gmtCreate}, #{gmtModified},
        #{processDefinitionIdAndVersion},#{processDefinitionType},#{startUserId},
        #{status}, #{completeTime}, #{parentProcessInstanceId},#{parentExecutionInstanceId}, #{reason}, #{bizUniqueId}, #{title},
        #{tag},#{comment},
        #{tenantId})
    </insert>


    <delete id="delete" parameterType="long">
        delete
        from se_process_instance
        where id = #{id}
        <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
    </delete>

    <update id="update"
            parameterType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity">
        update se_process_instance
        <set>
            gmt_modified=CURRENT_TIMESTAMP
            <if test="status != null">,status = #{status}</if>
            <if test="completeTime != null">,complete_time = #{completeTime}</if>
            <if test="parentProcessInstanceId != null">,parent_process_instance_id = #{parentProcessInstanceId}</if>
            <if test="reason != null">,reason = #{reason}</if>
            <if test="tag != null">,tag = #{tag}</if>
            <if test="comment != null">,comment = #{comment}</if>

        </set>
        where id=#{id}
        <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
    </update>

    <select id="findOne"
            resultType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity">
        select
        <include refid="baseColumn"/>
        from se_process_instance
        where id=#{id}
        <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
    </select>

    <select id="tryLock"
            resultType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity">
        select
        <include refid="baseColumn"/>
        from se_process_instance
        where id=#{id}
        <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
        for update

    </select>

    <select id="findOneForUpdate"
            resultType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity">
        select
        <include refid="baseColumn"/>
        from se_process_instance
        where  id=#{id}
        <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
        for update
    </select>


    <select id="find" resultType="com.alibaba.smart.framework.engine.persister.database.entity.ProcessInstanceEntity"
            parameterType="com.alibaba.smart.framework.engine.service.param.query.ProcessInstanceQueryParam">
        select
        <include refid="baseColumn"/>
        from se_process_instance
        <include refid="condition"/>
        <include refid="order_by"/>
        <if test="pageOffset != null and pageSize != null">limit #{pageSize} offset #{pageOffset}</if>

    </select>

    <select id="count" resultType="long"
            parameterType="com.alibaba.smart.framework.engine.service.param.query.ProcessInstanceQueryParam">
        select count(*)
        from se_process_instance
        <include refid="condition"/>

    </select>

    <sql id="condition">
        <where>
            <if test="tenantId != null"> and tenant_id = #{tenantId} </if>
            <if test="processDefinitionType != null">and process_definition_type = #{processDefinitionType}</if>
            <if test="processDefinitionIdAndVersion != null">and process_definition_id_and_version =
                #{processDefinitionIdAndVersion}
            </if>
            <if test="status != null">and status = #{status}</if>
            <if test="startUserId != null">and start_user_id = #{startUserId}</if>
            <if test="parentInstanceId != null">and parent_process_instance_id = #{parentInstanceId, typeHandler=com.alibaba.smart.framework.engine.persister.database.handler.SmartIdTypeHandler}</if>
            <if test="bizUniqueId != null">and biz_unique_id = #{bizUniqueId}</if>
            <if test="processStartTime != null">and gmt_create <![CDATA[>=]]> #{processStartTime}</if>
            <if test="processEndTime != null">and gmt_create <![CDATA[<]]> #{processEndTime}</if>
            <if test="completeTimeStart != null">and complete_time <![CDATA[>=]]> #{completeTimeStart}</if>
            <if test="completeTimeEnd != null">and complete_time <![CDATA[<]]> #{completeTimeEnd}</if>
            <if test="processInstanceIdList != null">
                and id in
                <foreach item="item" index="index" separator="," open="(" close=")" collection="processInstanceIdList">
                    #{item, typeHandler=com.alibaba.smart.framework.engine.persister.database.handler.SmartIdTypeHandler}
                </foreach>
            </if>
            <if test="processDefinitionTypeList != null and processDefinitionTypeList.size() > 0">
                and process_definition_type in
                <foreach item="item" collection="processDefinitionTypeList" separator="," open="(" close=")">
                    #{item}
                </foreach>
            </if>
        </where>
    </sql>

    <!-- Dynamic order by support for fluent query API -->
    <sql id="order_by">
        <choose>
            <when test="orderBySpecs != null and orderBySpecs.size() > 0">
                ORDER BY
                <foreach item="spec" collection="orderBySpecs" separator=",">
                    ${spec.columnName} ${spec.directionSql}
                </foreach>
            </when>
            <otherwise>
                ORDER BY gmt_modified DESC
            </otherwise>
        </choose>
    </sql>


</mapper>
